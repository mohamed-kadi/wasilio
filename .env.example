# Local Docker Compose development variables.
# Production must set JWT_SECRET from deployment secrets, not this file.
POSTGRES_DB=nexora
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
JWT_SECRET=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173
APP_FRONTEND_BASE_URL=http://localhost
VITE_PUBLIC_SITE_URL=http://localhost
VITE_PUBLIC_SUPPORT_EMAIL=support@wasilio.local
VITE_PUBLIC_WHATSAPP_URL=
VITE_PUBLIC_META_PIXEL_ID=
APP_EMAIL_MODE=log
APP_EMAIL_FROM=Wasilio <no-reply@wasilio.local>
APP_SUPPORT_CONTACT=support@wasilio.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS_ENABLE=false
APP_ONBOARDING_ENABLED=true
APP_PASSWORD_RESET_TOKEN_TTL=PT30M
APP_SUPER_ADMIN_BOOTSTRAP_ENABLED=false
APP_SUPER_ADMIN_EMAIL=
APP_SUPER_ADMIN_PASSWORD=
APP_SUPER_ADMIN_TENANT_NAME=Wasilio Internal
APP_SECURITY_THROTTLING_ENABLED=true
APP_LOGIN_THROTTLE_MAX_ATTEMPTS=5
APP_LOGIN_THROTTLE_WINDOW=PT10M
APP_LOGIN_THROTTLE_LOCKOUT=PT15M
APP_ONBOARDING_THROTTLE_MAX_ATTEMPTS=3
APP_ONBOARDING_THROTTLE_WINDOW=PT1H
APP_ONBOARDING_THROTTLE_LOCKOUT=PT1H
APP_PASSWORD_RESET_THROTTLE_MAX_ATTEMPTS=3
APP_PASSWORD_RESET_THROTTLE_WINDOW=PT1H
APP_PASSWORD_RESET_THROTTLE_LOCKOUT=PT1H
SPRING_FLYWAY_OUT_OF_ORDER=true

# Host ports used by Docker Compose.
# Change these when another local process is already using the default ports.
FRONTEND_PORT=80
BACKEND_PORT=8080
POSTGRES_PORT=5432

# Local backup helper defaults.
# Production should write to encrypted/off-host storage after each successful dump.
BACKUP_DIR=backups
BACKUP_PREFIX=wasilio
BACKUP_RETENTION_DAYS=14
